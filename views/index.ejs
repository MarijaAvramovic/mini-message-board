<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>

  <link rel="stylesheet" href="/style.css">
    
</head>

<body>
  <div class="container">
    
    <div class="header">
      <h1><%= title %></h1>
      <a class="new-btn" href="/new">+ New</a>
    </div>


    <div class="messages">
      <% if (messages.length === 0) { %>
        <div class="empty">No messages yet.</div>
      <% } %>

    <div class="messages">
      <% messages.forEach(message => { %>
        <div class="message">
          <div class="user"><%= message.username %></div>
          <div class="text"><%= message.text %></div>
          <div class="date"><%= message.added.toLocaleString() %></div>
          <a class="open-btn" href="/message/<%= message.id %>">Open</a>
          <a class="open-btn" href="/delete/<%= message.id %>">Delete</a>
        </div>
      <% }) %>
    </div>
  </div>
</body>
</html>